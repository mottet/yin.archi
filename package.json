{
  "name": "yin.archi",
  "version": "1.0.0",
  "description": "YIN Pei-Hua's (Jocelyn) portfolio ",
  "repository": "git@github.com:mottet/yin.archi.git",
  "author": "Marvin Mottet <11558282+mottet@users.noreply.github.com>",
  "license": "CC-BY-NC-ND-4.0",
  "scripts": {
    "start": "npm-run-all --parallel 'watch:*'",
    "watch:start": "parcel serve src/index.html --dist-dir serve",
    "watch:css": "tailwindcss -i src/style.scss -o src/assets/tailwind.css -w --minify",
    "build": "yarn parcel build src/**/*.html"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.2",
    "cssnano": "^5.0.15",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.2.0",
    "postcss": "^8.4.5",
    "tailwindcss": "^3.0.13"
  }
}
